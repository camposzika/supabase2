create table alunos (
  id bigint generated always as produto primary key not null,
  coluna1 text,
  coluna2 varchar(15),
  coluna3 int,
);
--entidade geralmente se refere a tabela que voces querem criar--
--coluna1 foi colocado como texto(text) que é a premissa mais basica de escrita--
--coluna2 foi utilizado o varchar para mostrar como voce limita a quantidade de caracteres--
--coluna3 se refere ao item de configuração mais basico para inserir numeros (int esta associado a inteiro, ou seja, o numero inteiro)--
